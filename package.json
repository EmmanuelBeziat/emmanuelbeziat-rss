{
  "name": "emmanuelbeziat-rss",
  "version": "2.0.0",
  "type": "module",
  "description": "📰 RSS file creation on push hooks? Yeah!",
  "main": "src/index.ts",
  "bin": {
    "rss-build": "src/cli.ts"
  },
  "scripts": {
    "start": "node -r dotenv/config src/cli.ts",
    "setup": "npm i && node setup.js",
    "lint": "npx eslint .",
    "test": "vitest --run",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts}": [
      "npx eslint"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmmanuelBeziat/emmanuelbeziat-rss.git"
  },
  "keywords": [
    "nodejs",
    "rss"
  ],
  "author": {
    "name": "Emmanuel Béziat",
    "email": "contact@emmanuelbeziat.com"
  },
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/EmmanuelBeziat/emmanuelbeziat-rss/issues"
  },
  "homepage": "https://github.com/EmmanuelBeziat/emmanuelbeziat-rss#readme",
  "dependencies": {
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "jstoxml": "^7.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "babel-jest": "^30.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
